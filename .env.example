# ─── JobAgent Environment Variables ───────────────────────────────
#
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
#
# Required for Groq cloud inference (default provider — free tier available):
#   Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: Serper search API (used for Google job discovery fallback)
SERPER_API_KEY=
